{
  "servers": {
    "workMemory": {
      "type": "stdio",
      "command": "node",
      "args": [
        "playable-shared-kit/tools/work-memory-mcp.cjs"
      ],
      "cwd": "${workspaceFolder}",
      "dev": {
        "watch": [
          "playable-shared-kit/tools/work-memory-mcp.cjs",
          "playable-shared-kit/tools/work-memory.cjs",
          "playable-shared-kit/tools/work-memory/**/*.js"
        ]
      }
    },
    "cocos-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:3000/mcp"
    }
  }
}
