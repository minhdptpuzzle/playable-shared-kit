{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Extension definition file",
    "properties": {
        "author": {
            "type": "string",
            "description": "Author",
            "default": "Cocos Creator Developer"
        },
        "contributions": {
            "$ref": "./contributions/index.json"
        },
        "dependencies": {
            "type": "object",
            "description": "Dependencies required for publishing"
        },
        "description": {
            "type": "string",
            "description": "Brief summary of the extension's key features and purpose. Supports i18n."
        },
        "devDependencies": {
            "type": "object",
            "description": "Dependencies required for development"
        },
        "editor": {
            "type": "string",
            "description": "Supported Cocos Creator editor version. Uses semver format."
        },
        "main": {
            "type": "string",
            "description": "Entry point",
            "default": "./dist/index.js"
        },
        "name": {
            "type": "string",
            "description": "Cannot start with _ or ., cannot contain uppercase letters, and cannot contain characters that are invalid in URLs, such as ., ' and ,.",
            "default": "Custom Extension"
        },
        "package_version": {
            "type": "number",
            "description": "Reserved version number for the extension system",
            "default": 2
        },
        "panels": {
            "$ref": "./base/panels.json"
        },
        "scripts": {
            "type": "object",
            "description": "NPM scripts"
        },
        "version": {
            "type": "string",
            "description": "Version string",
            "default": "1.0.0"
        }
    },
    "required": [
        "author",
        "name",
        "package_version",
        "version"
    ]
}